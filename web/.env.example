# Database — defaults to SQLite for zero-config dev. Switch to Postgres for prod.
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:pass@localhost:5432/greenkart?schema=public"

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_BRAND_NAME="GreenKart"

# Currency / locale
NEXT_PUBLIC_CURRENCY="USD"
NEXT_PUBLIC_LOCALE="en-US"

# Free shipping threshold
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD="50"

# Tax rate (0.00 - 1.00)
NEXT_PUBLIC_TAX_RATE="0.08"

# Payment providers (stub for now)
SSLCOMMERZ_STORE_ID=""
SSLCOMMERZ_STORE_PASSWORD=""
SSLCOMMERZ_SANDBOX="true"

BKASH_APP_KEY=""
BKASH_APP_SECRET=""
BKASH_USERNAME=""
BKASH_PASSWORD=""

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email
RESEND_API_KEY=""
RESEND_FROM="GreenKart <hello@greenkart.demo>"

# Search (optional in dev)
TYPESENSE_HOST=""
TYPESENSE_API_KEY=""
